{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "endOfLine": "lf",
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "coverage/",
    "test-results/",
    "playwright-report/",
    "*.min.js",
    "*.min.css",
    "__pycache__/",
    ".venv/",
    ".pytest_cache/",
    "backend/",
    ".worktrees/",
    "package-lock.json"
  ]
}
