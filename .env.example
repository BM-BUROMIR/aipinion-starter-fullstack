# Auth server
AUTH_SERVER_URL=https://auth.aipinion.ru
APP_SLUG=starter
COOKIE_NAME=auth_token

# Frontend (Vite env vars must start with VITE_)
VITE_AUTH_SERVER_URL=https://auth.aipinion.ru
VITE_APP_SLUG=starter
VITE_API_URL=/api

# Backend
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
DISABLE_AUTH=1
